def render_table(highlight_col):
    """Render the three comparison sub-tables as Markdown, marking the column
    that corresponds to the current model's backbone."""
    headers = ["WSP", "WSP-L", "MMS-1B"]
    out = []
    for metric, rows in TABLE.items():
        cols = list(headers)
        cols[highlight_col] = f"{cols[highlight_col]} ← this model"
        out.append(f"**{metric}**\n")
        out.append("| Language Classifier | " + " | ".join(cols) + " |")
        out.append("|" + "---|" * 4)
        for name, *vals in rows:
            out.append(f"| {name} | " + " | ".join(vals) + " |")
        out.append("")
    return "\n".join(out)


